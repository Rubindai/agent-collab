{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-collab/host-first-pass.schema.json",
  "title": "Agent Collab Host First Pass",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "summary", "claims"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "summary": {"type": "string"},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "status", "evidence"],
        "additionalProperties": false,
        "properties": {
          "claim": {"type": "string"},
          "status": {
            "enum": [
              "confirmed",
              "plausible_unverified",
              "rejected",
              "product_decision",
              "needs_human_input"
            ]
          },
          "evidence": {"type": "string"}
        }
      }
    }
  }
}
