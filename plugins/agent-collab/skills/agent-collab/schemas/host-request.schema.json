{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-collab/host-request.schema.json",
  "title": "Agent Collab Host Request v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "origin",
    "host",
    "peer",
    "mode",
    "target",
    "brief",
    "edit_allowed",
    "run_id",
    "profile",
    "local_subagents_allowed",
    "max_local_subagents",
    "online_research",
    "safe_mode",
    "peer_model",
    "peer_effort",
    "availability_attestation",
    "peer_timeout_seconds",
    "codex_config",
    "claude_tools",
    "claude_max_turns"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "origin": {"enum": ["claude", "codex"]},
    "host": {"enum": ["claude", "codex"]},
    "peer": {"enum": ["claude", "codex"]},
    "mode": {"enum": ["review", "research", "design", "plan", "debug"]},
    "target": {"type": "string", "minLength": 1},
    "brief": {"type": "string", "minLength": 1},
    "edit_allowed": {"type": "boolean"},
    "run_id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9._-]+$"},
    "profile": {"enum": ["standard", "max", "ultra"]},
    "local_subagents_allowed": {"type": "boolean"},
    "max_local_subagents": {"type": "integer", "minimum": 0, "maximum": 64},
    "online_research": {"type": "boolean"},
    "safe_mode": {"type": "boolean"},
    "peer_model": {"type": "string", "minLength": 1},
    "peer_effort": {"type": "string", "minLength": 1},
    "availability_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "status",
        "peer",
        "requested_model",
        "requested_effort",
        "supported_efforts",
        "source",
        "checked_at",
        "cli_version",
        "effort_evidence",
        "evidence_sha256",
        "details"
      ],
      "properties": {
        "schema_version": {"const": "2.0"},
        "status": {"const": "available"},
        "peer": {"enum": ["claude", "codex"]},
        "requested_model": {"type": "string", "minLength": 1},
        "requested_effort": {"type": "string", "minLength": 1},
        "supported_efforts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "source": {"enum": ["codex_debug_models", "claude_cli_probe"]},
        "checked_at": {"type": "string", "minLength": 1},
        "cli_version": {"type": "string", "minLength": 1},
        "effort_evidence": {
          "enum": ["catalog_advertised", "stop_hook_observed"]
        },
        "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "details": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"peer": {"const": "codex"}}, "required": ["peer"]},
          "then": {
            "properties": {
              "source": {"const": "codex_debug_models"},
              "effort_evidence": {"const": "catalog_advertised"}
            }
          }
        },
        {
          "if": {"properties": {"peer": {"const": "claude"}}, "required": ["peer"]},
          "then": {
            "properties": {
              "source": {"const": "claude_cli_probe"},
              "effort_evidence": {"const": "stop_hook_observed"}
            }
          }
        }
      ]
    },
    "peer_timeout_seconds": {"type": "number", "minimum": 2700, "maximum": 86400},
    "codex_config": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[^=]+="}
    },
    "claude_tools": {"type": "string", "minLength": 1},
    "claude_max_turns": {"type": "integer", "minimum": 1, "maximum": 1000}
  }
}
