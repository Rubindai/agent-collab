{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-collab/helper-reports.schema.json",
  "title": "Agent Collab Helper Reports v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "reports"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "reports": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "summary", "claims"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "summary": {"type": "string"},
          "claims": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["claim", "status", "evidence"],
              "properties": {
                "claim": {"type": "string"},
                "status": {
                  "enum": [
                    "confirmed",
                    "plausible_unverified",
                    "rejected",
                    "product_decision",
                    "needs_human_input"
                  ]
                },
                "evidence": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
