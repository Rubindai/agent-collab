{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-collab/settings.schema.json",
  "title": "Agent Collab Settings v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "updated_at", "settings"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "updated_at": {"type": "string", "minLength": 1},
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "local_subagents_allowed",
        "max_local_subagents",
        "agent_timeout_seconds",
        "safe_mode",
        "codex_model",
        "codex_effort",
        "online_research",
        "codex_config",
        "claude_model",
        "claude_effort",
        "claude_tools",
        "claude_max_turns",
        "history_retained_runs"
      ],
      "properties": {
        "profile": {"enum": ["standard", "max", "ultra"]},
        "local_subagents_allowed": {"type": "boolean"},
        "max_local_subagents": {"type": "integer", "minimum": 0, "maximum": 64},
        "agent_timeout_seconds": {
          "type": "string",
          "pattern": "^(?:(?:2[7-9][0-9]{2}|[3-9][0-9]{3}|[1-7][0-9]{4}|8[0-5][0-9]{3}|86[0-3][0-9]{2})(?:\\.[0-9]+)?|86400(?:\\.0+)?)$"
        },
        "safe_mode": {"type": "boolean"},
        "codex_model": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "codex_effort": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "online_research": {"type": "boolean"},
        "codex_config": {"type": "array", "items": {"type": "string", "pattern": "^[^=]+="}},
        "claude_model": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "not": {
            "pattern": "^\\s*(?:[Ff][Aa][Bb][Ll][Ee]|[Cc][Ll][Aa][Uu][Dd][Ee]-[Ff][Aa][Bb][Ll][Ee]-)"
          }
        },
        "claude_effort": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "claude_tools": {"type": "string", "minLength": 1, "pattern": "\\S"},
        "claude_max_turns": {
          "type": "string",
          "pattern": "^(?:[1-9]|[1-9][0-9]|[1-9][0-9]{2}|1000)$"
        },
        "history_retained_runs": {"type": "integer", "minimum": 0}
      }
    }
  }
}
