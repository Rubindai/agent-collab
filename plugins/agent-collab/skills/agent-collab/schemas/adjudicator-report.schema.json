{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-collab/adjudicator-report.schema.json",
  "title": "Agent Collab Advisory Adjudicator Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "status", "summary", "false_positives", "claims_needing_verification", "recommended_verdict"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["advisory_pending", "ok", "needs_human_input", "blocked"]},
    "summary": {"type": "string"},
    "false_positives": {"type": "array", "items": {"type": "string"}},
    "claims_needing_verification": {"type": "array", "items": {"type": "string"}},
    "recommended_verdict": {
      "enum": [
        "pass",
        "pass_with_concerns",
        "changes_recommended",
        "ready",
        "needs_revision",
        "blocked",
        "informational"
      ]
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "status", "evidence"],
        "properties": {
          "claim": {"type": "string"},
          "status": {
            "enum": [
              "confirmed",
              "plausible_unverified",
              "rejected",
              "product_decision",
              "needs_human_input"
            ]
          },
          "evidence": {"type": "string"}
        }
      },
      "default": []
    }
  }
}
