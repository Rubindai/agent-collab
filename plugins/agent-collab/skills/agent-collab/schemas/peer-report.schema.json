{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "origin",
    "host",
    "peer",
    "mode",
    "target",
    "status",
    "verdict",
    "summary",
    "findings",
    "claims",
    "limitations",
    "next_actions",
    "error"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "origin": {
      "enum": ["claude", "codex"]
    },
    "host": {
      "enum": ["claude", "codex"]
    },
    "peer": {
      "enum": ["claude", "codex"]
    },
    "mode": {
      "enum": [
        "review",
        "research",
        "design",
        "plan",
        "debug"
      ]
    },
    "target": {
      "type": "string"
    },
    "status": {
      "enum": ["ok", "peer_failed"]
    },
    "verdict": {
      "enum": [
        "pass",
        "pass_with_concerns",
        "changes_recommended",
        "ready",
        "needs_revision",
        "blocked",
        "informational"
      ]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "details", "files", "recommendation", "confidence"],
        "properties": {
          "severity": {
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "title": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 0
          },
          "recommendation": {
            "type": "string"
          },
          "confidence": {
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "status", "evidence"],
        "properties": {
          "claim": {
            "type": "string"
          },
          "status": {
            "enum": [
              "confirmed",
              "plausible_unverified",
              "rejected",
              "product_decision",
              "needs_human_input"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "message", "details"],
          "properties": {
            "kind": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "details": {
              "type": ["string", "null"]
            }
          }
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
