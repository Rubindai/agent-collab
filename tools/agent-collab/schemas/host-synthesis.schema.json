{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-collab/host-synthesis.schema.json",
  "title": "Agent Collab Host Synthesis v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "summary",
    "verdict",
    "claims",
    "unresolved_risks",
    "workspace_mutation_sha256",
    "final_answer_ready"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "run_id": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "verdict": {
      "enum": [
        "pass",
        "pass_with_concerns",
        "changes_recommended",
        "ready",
        "needs_revision",
        "blocked",
        "informational"
      ]
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "status", "evidence"],
        "properties": {
          "claim": {"type": "string"},
          "status": {
            "enum": [
              "confirmed",
              "plausible_unverified",
              "rejected",
              "product_decision",
              "needs_human_input"
            ]
          },
          "evidence": {"type": "string"}
        }
      }
    },
    "unresolved_risks": {"type": "array", "items": {"type": "string"}},
    "workspace_mutation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "final_answer_ready": {"const": true}
  }
}
