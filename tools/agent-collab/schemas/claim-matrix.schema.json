{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.agent-collab/claim-matrix.schema.json",
  "title": "Agent Collab Claim Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "claims"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source"],
        "additionalProperties": true,
        "properties": {
          "source": {"enum": ["host", "peer", "helper", "adjudicator"]}
        }
      }
    }
  }
}
