# Python caches
__pycache__/
*.py[cod]
*$py.class

# Test and type-checker caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local environment files
.env
.env.*
!.env.example

# Editor and OS metadata
.DS_Store
.vscode/
.idea/
.agents/
.codex/
.claude/

# Logs and temporary files
*.log
tmp/
temp/
.tmp/
.temp/
tools/agent-collab/runs/*
